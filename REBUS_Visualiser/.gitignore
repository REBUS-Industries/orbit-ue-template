# --- Unreal Engine generated / per-machine artefacts ---
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Plugin build outputs (never commit compiled plugin binaries / intermediates)
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Per-user editor scratch content (developer collections etc.)
Content/Developers/

# Auto-generated base level -- init_unreal.py regenerates it at editor startup
# (see Content/Python/build_rebus_base_level.py), so it is a derived artefact.
Content/REBUS/Maps/

# Python bytecode cache
Content/Python/__pycache__/

# Visual Studio / Rider / Xcode IDE files
.vs/
.idea/
.vscode/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj
*.xcworkspace

# Project descriptor backups (never commit these)
*.uproject.bak*
*.orig-backup
*.uplugin.bak*

# Build logs
*.log

# OS noise
.DS_Store
Thumbs.db
desktop.ini
